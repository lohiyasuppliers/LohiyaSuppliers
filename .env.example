# Database — local MongoDB (auto-started by npm run dev) or MongoDB Atlas for production
# Local: mongodb://127.0.0.1:27018/lohiyasuppliers?replicaSet=rs0
# Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/lohiyasuppliers?retryWrites=true&w=majority
DATABASE_URL="mongodb://127.0.0.1:27018/lohiyasuppliers?replicaSet=rs0"

# Auth.js (NextAuth)
NEXTAUTH_SECRET="change-this-to-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Business (GST invoicing)
BUSINESS_GSTIN=""
BUSINESS_STATE="Rajasthan"

# Razorpay (Module 6)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Image storage — Cloudinary OR S3 (Module 2)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email — Resend or SMTP (Module 6+)
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
