{
  "name": "lohiya-suppliers",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-mongo.mjs",
    "dev": "prisma generate && next dev --turbopack -p 3000",
    "dev:webpack": "prisma generate && next dev -p 3000",
    "dev:turbo": "prisma generate && next dev --turbopack -p 3000",
    "host": "next dev -H 0.0.0.0 -p 3000",
    "dev:clean": "node scripts/fix-dev.mjs",
    "fix": "node scripts/fix-dev.mjs",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "preview": "npm run build && npm run start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:setup": "node scripts/ensure-mongo.mjs && prisma db push --accept-data-loss && npm run db:seed",
    "db:atlas": "node scripts/atlas-provision.mjs",
    "db:finish-atlas": "node scripts/finish-atlas.mjs",
    "atlas:login": "scripts\\atlas-login.cmd",
    "mongo:start": "node scripts/ensure-mongo.mjs",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:refresh-images": "tsx prisma/refresh-images.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "mongodb-memory-server": "^11.2.0",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
