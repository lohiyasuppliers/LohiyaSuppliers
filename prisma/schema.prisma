generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

enum CategoryType {
  PRODUCT
  SERVICE
}

enum ApplicationType {
  METAL
  WOOD
  BOTH
}

enum OrderType {
  PREPAID
  POSTPAID
}

enum OrderStatus {
  PENDING_APPROVAL
  APPROVED_PAID
  APPROVED_UNPAID
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  PENDING_VERIFICATION
  FAILED
  REFUNDED
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum VoucherScope {
  WHOLE_BILL
  PRODUCT
  SERVICE
}

enum CashbackType {
  FIXED
  PERCENTAGE
}

enum CashbackLedgerType {
  EARNED
  REDEEMED_BILL
  REDEEMED_AMAZON
  REDEEMED_UPI
}

enum CashbackRedemptionType {
  NEXT_BILL
  AMAZON_VOUCHER
  UPI
}

enum RedemptionStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum CashbackWalletStatus {
  LOCKED
  AVAILABLE
  REDEEMED
  EXPIRED
}

enum CashbackWalletSource {
  ORDER
  ADMIN
}

// Sentinel for product-level price/cashback overrides (no variation)
// Use this constant in application code instead of null.
// PRODUCT_LEVEL_VARIATION_ID = "__product__"

// ─── Users & clients ─────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  role      Role     @default(CLIENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile       ClientProfile?
  priceOverrides      ClientPriceOverride[]
  orders              Order[]
  cashbackRules       CashbackRule[]
  productDiscountRules ProductDiscountRule[]
  cashbackLedger      CashbackLedgerEntry[]
  vouchers            ClientVoucher[]
  cashbackRedemptions CashbackRedemption[]
  clientBills         ClientBill[]
  discountRules       ClientDiscountRule[]
  cashbackWallet      CashbackWalletEntry[]
}

model ClientProfile {
  id                   String  @id @default(cuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company              String
  gstin                String?
  billingState         String
  address              String?
  city                 String?
  pincode              String?
  country              String  @default("India")
  cashbackBalancePaise Int     @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  type        CategoryType
  application ApplicationType  @default(BOTH)
  parentId    String?
  parent      Category?        @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]       @relation("CategoryTree")
  imageUrl    String?
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  products  Product[]
  vouchers  ClientVoucher[]

  @@index([parentId])
  @@index([application])
}

model Product {
  id                String   @id @default(cuid())
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  name              String
  slug              String   @unique
  brand             String?
  description       String
  hsnCode           String   @default("")
  gstRateBps        Int      @default(1800) // basis points: 1800 = 18%
  defaultPricePaise Int
  images            String   @default("[]")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  variations     ProductVariation[]
  priceOverrides ClientPriceOverride[]
  cashbackRules  CashbackRule[]
  productDiscountRules ProductDiscountRule[]
  orderItems     OrderItem[]
  vouchers       ClientVoucher[]

  @@index([isActive])
  @@index([categoryId, isActive])
  @@index([brand])
}

model ProductVariation {
  id                  String   @id @default(cuid())
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                 String   @unique
  attributes          Json     // e.g. { "size": "4 inch" }
  imageUrl            String?
  defaultPricePaise   Int?     // overrides product default when set
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  orderItems     OrderItem[]

  @@index([productId, isActive])
}

// variationId on ClientPriceOverride

// ─── Per-client pricing ──────────────────────────────────────────────────────

model ClientPriceOverride {
  id          String           @id @default(cuid())
  clientId    String
  client      User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId   String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// "__product__" for product-level; otherwise variation id
  variationId String           @default("__product__")
  pricePaise  Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([clientId, productId, variationId])
  @@index([clientId])
  @@index([clientId, productId])
}

// ─── Orders & payments ───────────────────────────────────────────────────────

model Order {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  clientId             String
  client               User          @relation(fields: [clientId], references: [id])
  orderType            OrderType
  status               OrderStatus   @default(PENDING_APPROVAL)
  paymentStatus        PaymentStatus @default(UNPAID)
  paidPaise            Int           @default(0)
  pendingPaymentPaise  Int           @default(0)
  paymentProof         String?
  razorpayOrderId      String?
  razorpayPaymentId    String?
  subtotalPaise        Int
  taxPaise             Int           @default(0)
  discountPaise        Int           @default(0)
  voucherDiscountPaise Int           @default(0)
  cashbackAppliedPaise Int           @default(0)
  walletAppliedPaise   Int           @default(0)
  cashbackEarnedPaise  Int           @default(0)
  totalPaise           Int
  shippingAddress      Json
  billingAddress       Json?
  notes                String?
  voucherId            String?
  voucher              ClientVoucher? @relation(fields: [voucherId], references: [id])
  approvedAt           DateTime?
  approvedById         String?
  rejectionReason      String?
  adminComment         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  items            OrderItem[]
  cashbackLedger   CashbackLedgerEntry[]
  cashbackWallet   CashbackWalletEntry[]
}

model OrderItem {
  id              String            @id @default(cuid())
  orderId         String
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product           @relation(fields: [productId], references: [id])
  variationId     String?
  variation       ProductVariation? @relation(fields: [variationId], references: [id])
  productName     String
  variationLabel  String?
  hsnCode         String            @default("")
  gstRateBps      Int
  quantity        Int
  unitPricePaise  Int
  totalPaise      Int
}

// ─── Admin-generated client bills ────────────────────────────────────────────

model ClientBill {
  id          String   @id @default(cuid())
  clientId    String
  client      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  billNumber  String
  title       String?
  description String?
  fileUrl     String?
  amountPaise Int?
  billDate    DateTime @default(now())
  orderId     String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
}

// ─── Per-client discounts & cashback wallet ──────────────────────────────────

model ClientDiscountRule {
  id               String       @id @default(cuid())
  clientId         String
  client           User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title            String       @default("Order discount")
  type             DiscountType
  valuePaise       Int?
  valueBps         Int?
  minOrderPaise    Int          @default(0)
  maxDiscountPaise Int?
  isActive         Boolean      @default(true)
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([clientId, isActive])
}

model CashbackWalletEntry {
  id               String                 @id @default(cuid())
  clientId         String
  client           User                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orderId          String?
  order            Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  amountPaise      Int
  status           CashbackWalletStatus   @default(LOCKED)
  source           CashbackWalletSource   @default(ORDER)
  earnedAt         DateTime               @default(now())
  unlockedAt       DateTime?
  expiresAt        DateTime
  redeemedAt       DateTime?
  redemptionType   CashbackRedemptionType?
  adminNote        String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([clientId, status])
  @@index([orderId])
  @@index([expiresAt])
}

// ─── Cashback ────────────────────────────────────────────────────────────────

model CashbackRule {
  id          String           @id @default(cuid())
  clientId    String
  client      User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId   String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationId String           @default("__product__")
  type        CashbackType
  valuePaise  Int?
  valueBps    Int?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([clientId, productId, variationId])
}

model ProductDiscountRule {
  id          String       @id @default(cuid())
  clientId    String
  client      User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationId String       @default("__product__")
  type        DiscountType @default(FIXED)
  valuePaise  Int?
  valueBps    Int?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([clientId, productId, variationId])
}

model CashbackLedgerEntry {
  id                String             @id @default(cuid())
  clientId          String
  client            User               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type              CashbackLedgerType
  amountPaise       Int
  balanceAfterPaise Int
  orderId           String?
  order             Order?             @relation(fields: [orderId], references: [id])
  description       String
  createdAt         DateTime           @default(now())

  @@index([clientId, createdAt])
}

model CashbackRedemption {
  id              String                 @id @default(cuid())
  clientId        String
  client          User                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            CashbackRedemptionType
  amountPaise     Int
  status          RedemptionStatus       @default(PENDING)
  upiId           String?
  clientNote      String?
  adminComment    String?
  paymentProof    String?
  rejectionReason String?
  amazonCode      String?
  orderId         String?
  createdAt       DateTime               @default(now())
  fulfilledAt     DateTime?

  @@index([clientId, status])
}

// ─── Per-client vouchers ─────────────────────────────────────────────────────

model ClientVoucher {
  id            String        @id @default(cuid())
  clientId      String
  client        User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  code          String
  scope         VoucherScope
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id])
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  type          DiscountType
  valuePaise    Int?
  valueBps      Int?
  minOrderPaise Int           @default(0)
  maxUses       Int?
  usedCount     Int           @default(0)
  expiresAt     DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orders Order[]

  @@unique([clientId, code])
}

// ─── Platform settings ───────────────────────────────────────────────────────

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
